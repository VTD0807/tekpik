rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /visits/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['page','timestamp','source'])
                    && request.resource.data.page is string
                    && request.resource.data.source is string
                    && request.resource.data.timestamp is string;
      allow read, update, delete: if false;
    }

    match /session_ends/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['page','timestamp'])
                    && request.resource.data.page is string;
      allow read, update, delete: if false;
    }

    match /waitlist/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['email','timestamp'])
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*\\..*');
      // Allow authenticated users to query by email for duplicate check
      allow list: if request.auth != null;
      allow get, update, delete: if false;
    }

    match /newsletter/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['email','timestamp'])
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*\\..*');
      allow list: if request.auth != null;
      allow get, update, delete: if false;
    }

    match /consent_events/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['event','timestamp'])
                    && request.resource.data.event is string;
      allow read, update, delete: if false;
    }

    // user_history — service worker writes (no auth required since SW can't do anon auth easily)
    match /user_history/{docId} {
      allow create: if request.resource.data.keys().hasAll(['event_type','timestamp','visitor_id'])
                    && request.resource.data.event_type is string
                    && request.resource.data.visitor_id is string;
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
